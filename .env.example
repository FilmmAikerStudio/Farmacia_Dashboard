# =============================================================
# FARMACIA BARCELONA — Environment Variables Template
# Copy this to .env.local and fill in real values.
# =============================================================

# META / FACEBOOK
VITE_META_ACCESS_TOKEN=your_meta_user_access_token_here
VITE_META_PIXEL_ID=your_pixel_id_here

# GOOGLE — OAuth 2.0 (client_id only — safe for frontend)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
# GOOGLE_CLIENT_SECRET=server_side_only_never_expose

# Google Analytics 4 — Property ID (digits only)
VITE_GA4_PROPERTY_ID=

# Google My Business
VITE_GMB_ACCOUNT_ID=
VITE_GMB_LOCATION_ID=
